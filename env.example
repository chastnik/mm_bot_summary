# Пример конфигурации для Mattermost Summary Bot
# Скопируйте этот файл как .env и отредактируйте настройки

# Mattermost Configuration
MATTERMOST_URL=https://your-mattermost-instance.com
MATTERMOST_TOKEN=your-bot-token
MATTERMOST_BOT_USERNAME=summary-bot

# LLM Configuration (предустановлены для корпоративной LLM)
LLM_PROXY_TOKEN=llm_token
LLM_BASE_URL=url
LLM_MODEL=model_name

# Bot Configuration
BOT_PORT=8080
DEBUG=false 
WEB_API_TOKEN=change_me_strong_token

# Production deployment script configuration (scripts/install_prod_bot.sh, scripts/update_prod_bot.sh)
PROJECT_DIR=/opt/mattermost-summary-bot
REPO_URL=https://github.com/chastnik/mm_bot_summary.git
BRANCH=main
IMAGE_NAME=mattermost-summary-bot
IMAGE_TAG=prod
CONTAINER_NAME=mattermost-summary-bot-prod
HOST_PORT=8080
CONTAINER_PORT=8080